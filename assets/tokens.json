{
  "$schema": "https://design-tokens.org/schema.json",
  "_meta": {
    "name": "Rentaca — Minimalist (White/Black + Cornell Red)",
    "version": "2.0.0",
    "description": "Minimalist design tokens: white canvas, near-black ink, Cornell Red as the single primary accent used sparingly. Cornell palette only.",
    "accent_discipline": "Cornell Red appears only on: primary CTA, links, active filter state, price/rating accents, focus ring, and the brand dot. Deep Maroon is the red hover state. All other surfaces are white/ink/neutral-gray."
  },
  "color": {
    "core": {
      "cornell-red":   { "value": "#B31B1B", "type": "color", "use": "single primary accent (sparing)" },
      "deep-maroon":   { "value": "#6E0F0F", "type": "color", "use": "red hover only" },
      "cornell-black": { "value": "#000000", "type": "color" },
      "cornell-white": { "value": "#FFFFFF", "type": "color" }
    },
    "neutral": {
      "ink":      { "value": "#1A1A1A", "type": "color", "use": "primary text (17:1 on white)" },
      "gray-70":  { "value": "#595959", "type": "color", "use": "muted text — AA on white" },
      "gray-50":  { "value": "#8A8A8A", "type": "color", "use": "secondary/large text" },
      "gray-30":  { "value": "#C9C9C9", "type": "color", "use": "borders" },
      "line-100": { "value": "#ECECEC", "type": "color", "use": "hairlines" },
      "line-50":  { "value": "#F4F4F4", "type": "color", "use": "faint fills / hover wells" }
    },
    "semantic": {
      "bg":        { "value": "{color.core.cornell-white}", "type": "color" },
      "surface":   { "value": "{color.core.cornell-white}", "type": "color" },
      "text":      { "value": "{color.neutral.ink}", "type": "color" },
      "text-muted":{ "value": "{color.neutral.gray-70}", "type": "color" },
      "line":      { "value": "{color.neutral.line-100}", "type": "color" },
      "accent":    { "value": "{color.core.cornell-red}", "type": "color" },
      "accent-hover": { "value": "{color.core.deep-maroon}", "type": "color" }
    }
  },
  "contrast": {
    "_note": "WCAG ratios. PASS = AA normal (>=4.5).",
    "ink_on_white":         { "ratio": 17.4, "result": "AAA" },
    "gray-70_on_white":     { "ratio": 7.0, "result": "AA" },
    "gray-50_on_white":     { "ratio": 3.5, "result": "AA-large-only" },
    "cornell-red_on_white": { "ratio": 6.8, "result": "AA" },
    "white_on_cornell-red": { "ratio": 6.8, "result": "AA" }
  },
  "typography": {
    "fontFamily": {
      "display": { "value": "'Plus Jakarta Sans', system-ui, sans-serif", "type": "fontFamily" },
      "body":    { "value": "'Plus Jakarta Sans', system-ui, sans-serif", "type": "fontFamily" }
    },
    "scale": {
      "hero":  { "value": "clamp(40px, 6vw, 76px)", "type": "fontSize" },
      "h1":    { "value": "clamp(30px, 4.4vw, 52px)", "type": "fontSize" },
      "h2":    { "value": "clamp(23px, 2.8vw, 34px)", "type": "fontSize" },
      "h3":    { "value": "clamp(17px, 1.7vw, 20px)", "type": "fontSize" },
      "lead":  { "value": "clamp(17px, 1.9vw, 21px)", "type": "fontSize" },
      "body":  { "value": "17px", "type": "fontSize" },
      "small": { "value": "13.5px", "type": "fontSize" },
      "micro": { "value": "12px", "type": "fontSize" }
    },
    "weights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "lineHeight": { "tight": { "value": "1.05" }, "body": { "value": "1.55" } }
  },
  "spacing": {
    "baseline": { "value": "8px", "type": "dimension" },
    "1": { "value": "4px" }, "2": { "value": "8px" }, "3": { "value": "12px" },
    "4": { "value": "16px" }, "5": { "value": "24px" }, "6": { "value": "32px" },
    "7": { "value": "48px" }, "8": { "value": "64px" }, "9": { "value": "96px" }
  },
  "radius": {
    "sm": { "value": "8px" }, "md": { "value": "12px" },
    "lg": { "value": "16px" }, "xl": { "value": "20px" }
  },
  "elevation": {
    "1": { "value": "0 1px 2px rgba(0,0,0,.04)", "type": "shadow" },
    "2": { "value": "0 6px 20px rgba(0,0,0,.07)", "type": "shadow" },
    "3": { "value": "0 18px 50px rgba(0,0,0,.14)", "type": "shadow" }
  },
  "motion": {
    "ease":       { "value": "cubic-bezier(.4, 0, .2, 1)" },
    "duration": { "fast": { "value": "160ms" }, "base": { "value": "240ms" }, "slow": { "value": "500ms" } },
    "reducedMotion": { "value": "respect prefers-reduced-motion: disable entrance, near-zero transitions" }
  }
}
